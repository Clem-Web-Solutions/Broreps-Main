# Server Configuration
PORT=3005
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_at_least_32_characters_long

# CORS Configuration (comma-separated origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# CRON Secret (for scheduled tasks)
CRON_SECRET=your-cron-secret-key

# Shopify Configuration (if using Shopify)
SHOPIFY_SHOP_DOMAIN=your-shop.myshopify.com
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret

# TagadaPay Configuration
TAGADAPAY_API_KEY=your_tagadapay_api_key_here
TAGADAPAY_WEBHOOK_SECRET=your_tagadapay_webhook_secret_here
TAGADAPAY_ENVIRONMENT=development  # or production

# Optional: Custom TagadaPay API URL (defaults to production)
# TAGADAPAY_BASE_URL=https://app.tagadapay.dev/api/public/v1

# Frontend URL (for redirects)
FRONTEND_URL=http://localhost:5174

# Email Configuration (if using email notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_email_password
# SMTP_FROM=noreply@yoursite.com

# AI Configuration — Coach IA BroReps
OPENAI_API_KEY=sk-proj-...your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini  # default model (gpt-4o-mini recommended for cost)
# AI_DAILY_LIMIT=20           # messages per user per day

# File Upload Configuration
# UPLOAD_DIR=uploads
# MAX_FILE_SIZE=10485760  # 10MB in bytes

# Rate Limiting
# RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
# RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
# SESSION_SECRET=your_session_secret_key

# Logging
# LOG_LEVEL=info
# LOG_FILE=logs/server.log
